generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
  engineType       = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "public")]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum FirmType {
  LEGAL
  CONSULTING
  HYBRID
}

enum UserRole {
  ADMIN
  PARTNER
  ASSOCIATE
  ANALYST
  READONLY
}

enum MatterType {
  LEGAL
  CONSULTING
}

enum MatterStatus {
  ACTIVE
  CLOSED
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum AnalysisType {
  CONTRACT_RISK
  COMPARISON
  REDLINE
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BriefStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DraftType {
  EMAIL
  MEMO
  REPORT
}

enum DraftStatus {
  DRAFT
  REVIEWING
  FINALIZED
}

enum MeetingSource {
  ZOOM
  TEAMS
  MEET
  UPLOAD
}

enum MeetingStatus {
  PENDING
  PROCESSING
  COMPLETED
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum JobType {
  DOCUMENT_PARSE
  ANALYSIS_RUN
  BRIEF_GENERATE
  MEETING_PROCESS
  DRAFT_GENERATE
  CHUNK_EMBED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Firm {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String
  slug                String    @unique
  firmType            FirmType  @default(LEGAL) @map("firm_type")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  plan                String    @default("free")
  seatCount           Int       @default(5) @map("seat_count")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  users          User[]
  matters        Matter[]
  documents      Document[]
  documentChunks DocumentChunk[]
  analyses       Analysis[]
  researchBriefs ResearchBrief[]
  drafts         Draft[]
  meetings       Meeting[]
  kbQueries      KbQuery[]
  auditLogs      AuditLog[]
  playbooks      Playbook[]
  jobs           Job[]

  @@map("firms")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  firmId       String    @map("firm_id") @db.Uuid
  email        String    @unique
  name         String
  passwordHash String?   @map("password_hash")
  role         UserRole  @default(READONLY)
  avatarUrl    String?   @map("avatar_url")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  firm           Firm               @relation(fields: [firmId], references: [id], onDelete: Cascade)
  sessions       Session[]
  accounts       Account[]
  createdMatters Matter[]           @relation("MatterCreatedBy")
  uploadedDocs   Document[]         @relation("DocumentUploadedBy")
  createdBriefs  ResearchBrief[]    @relation("BriefCreatedBy")
  createdDrafts  Draft[]            @relation("DraftCreatedBy")
  kbQueries      KbQuery[]          @relation("KbQueryCreatedBy")
  auditLogs      AuditLog[]
  actionItems    MeetingActionItem[] @relation("ActionItemOwner")

  @@index([firmId])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Matter {
  id          String       @id @default(uuid()) @db.Uuid
  firmId      String       @map("firm_id") @db.Uuid
  name        String
  description String?
  type        MatterType   @default(LEGAL)
  status      MatterStatus @default(ACTIVE)
  clientName  String       @map("client_name")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  createdById String       @map("created_by_id") @db.Uuid

  firm           Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("MatterCreatedBy", fields: [createdById], references: [id])
  documents      Document[]
  researchBriefs ResearchBrief[]
  drafts         Draft[]
  meetings       Meeting[]
  kbQueries      KbQuery[]

  @@index([firmId])
  @@index([status])
  @@map("matters")
}

model Document {
  id           String         @id @default(uuid()) @db.Uuid
  firmId       String         @map("firm_id") @db.Uuid
  matterId     String?        @map("matter_id") @db.Uuid
  filename     String
  originalName String         @map("original_name")
  mimeType     String         @map("mime_type")
  sizeBytes    Int            @map("size_bytes")
  r2Key        String         @map("r2_key")
  status       DocumentStatus @default(UPLOADED)
  uploadedById String         @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  firm      Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  matter    Matter?          @relation(fields: [matterId], references: [id], onDelete: SetNull)
  uploadedBy User            @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  chunks    DocumentChunk[]
  analyses  Analysis[]

  @@index([firmId])
  @@index([matterId])
  @@index([status])
  @@map("documents")
}

model DocumentChunk {
  id           String @id @default(uuid()) @db.Uuid
  documentId   String @map("document_id") @db.Uuid
  firmId       String @map("firm_id") @db.Uuid
  chunkIndex   Int    @map("chunk_index")
  text         String
  sectionTitle String?  @map("section_title")
  pageNumber   Int?     @map("page_number")
  embedding    Unsupported("vector(768)")
  metadata     Json   @default("{}")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  firm     Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([firmId])
  @@map("document_chunks")
}

model Analysis {
  id          String         @id @default(uuid()) @db.Uuid
  documentId  String         @map("document_id") @db.Uuid
  firmId      String         @map("firm_id") @db.Uuid
  type        AnalysisType
  status      AnalysisStatus @default(PENDING)
  result      Json?
  modelUsed   String?        @map("model_used")
  createdAt   DateTime       @default(now()) @map("created_at")
  completedAt DateTime?      @map("completed_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  firm     Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([firmId])
  @@index([status])
  @@map("analyses")
}

model ResearchBrief {
  id          String      @id @default(uuid()) @db.Uuid
  matterId    String      @map("matter_id") @db.Uuid
  firmId      String      @map("firm_id") @db.Uuid
  title       String
  query       String
  status      BriefStatus @default(PENDING)
  result      Json?
  modelUsed   String?     @map("model_used")
  createdAt   DateTime    @default(now()) @map("created_at")
  completedAt DateTime?   @map("completed_at")
  createdById String      @map("created_by_id") @db.Uuid

  matter    Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  firm      Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  createdBy User   @relation("BriefCreatedBy", fields: [createdById], references: [id])

  @@index([matterId])
  @@index([firmId])
  @@index([status])
  @@map("research_briefs")
}

model Draft {
  id          String      @id @default(uuid()) @db.Uuid
  firmId      String      @map("firm_id") @db.Uuid
  matterId    String?     @map("matter_id") @db.Uuid
  type        DraftType
  title       String
  content     String      @default("")
  status      DraftStatus @default(DRAFT)
  instructions String?
  modelUsed   String?     @map("model_used")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  createdById String      @map("created_by_id") @db.Uuid

  firm      Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  matter    Matter? @relation(fields: [matterId], references: [id], onDelete: SetNull)
  createdBy User    @relation("DraftCreatedBy", fields: [createdById], references: [id])

  @@index([firmId])
  @@index([matterId])
  @@index([status])
  @@map("drafts")
}

model Meeting {
  id          String        @id @default(uuid()) @db.Uuid
  firmId      String        @map("firm_id") @db.Uuid
  matterId    String?       @map("matter_id") @db.Uuid
  title       String
  transcript  String?
  meetingDate DateTime      @map("meeting_date")
  source      MeetingSource @default(UPLOAD)
  status      MeetingStatus @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")

  firm         Firm                @relation(fields: [firmId], references: [id], onDelete: Cascade)
  matter       Matter?             @relation(fields: [matterId], references: [id], onDelete: SetNull)
  actionItems  MeetingActionItem[]
  decisions    MeetingDecision[]

  @@index([firmId])
  @@index([matterId])
  @@index([status])
  @@map("meetings")
}

model MeetingActionItem {
  id        String           @id @default(uuid()) @db.Uuid
  meetingId String           @map("meeting_id") @db.Uuid
  text      String
  ownerId   String?          @map("owner_id") @db.Uuid
  dueDate   DateTime?        @map("due_date")
  status    ActionItemStatus @default(OPEN)
  createdAt DateTime         @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  owner   User?   @relation("ActionItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([meetingId])
  @@index([ownerId])
  @@map("meeting_action_items")
}

model MeetingDecision {
  id        String   @id @default(uuid()) @db.Uuid
  meetingId String   @map("meeting_id") @db.Uuid
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("meeting_decisions")
}

model KbQuery {
  id           String   @id @default(uuid()) @db.Uuid
  firmId       String   @map("firm_id") @db.Uuid
  question     String
  matterId     String?  @map("matter_id") @db.Uuid
  answer       String?
  sourceChunks Json?    @map("source_chunks")
  confidence   Float?
  modelUsed    String?  @map("model_used")
  createdAt    DateTime @default(now()) @map("created_at")
  createdById  String   @map("created_by_id") @db.Uuid

  firm      Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  matter    Matter? @relation(fields: [matterId], references: [id], onDelete: SetNull)
  createdBy User    @relation("KbQueryCreatedBy", fields: [createdById], references: [id])

  @@index([firmId])
  @@index([matterId])
  @@map("kb_queries")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  firmId       String   @map("firm_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  details      Json?
  modelUsed    String?  @map("model_used")
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Playbook {
  id          String   @id @default(uuid()) @db.Uuid
  firmId      String   @map("firm_id") @db.Uuid
  name        String
  description String?
  rules       Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@map("playbooks")
}

model Job {
  id          String    @id @default(uuid()) @db.Uuid
  firmId      String    @map("firm_id") @db.Uuid
  type        JobType
  status      JobStatus @default(PENDING)
  result      Json?
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([status])
  @@index([type])
  @@map("jobs")
}
