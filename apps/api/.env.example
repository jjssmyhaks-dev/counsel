# ─── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Auth ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# ─── Database (Neon PostgreSQL / any Postgres + pgvector) ──
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── AI Service ────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ─── SSO (WorkOS) ──────────────────────────────────────────
WORKOS_API_KEY=sk_test_xxxxxxxx
WORKOS_CLIENT_ID=client_xxxxxxxx
WORKOS_REDIRECT_URI=http://localhost:3001/api/v1/auth/callback

# ─── Frontend URL (for CORS / callbacks) ───────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx
